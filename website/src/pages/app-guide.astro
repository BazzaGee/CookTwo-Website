---
import { getEntry, render } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';

const page = await getEntry('pages', 'app-guide');
if (!page) {
  throw new Error('app-guide page not found');
}
const { Content } = await render(page);
---

<PageLayout
  title={page.data.title}
  description={page.data.description}
  pubDate={page.data.pubDate}
  updatedDate={page.data.updatedDate}
  author={page.data.author}
  ogImage={page.data.ogImage}
  pillar={page.data.pillar}
  pageType="guide"
  tags={page.data.tags}
>
  <Content />
</PageLayout>
