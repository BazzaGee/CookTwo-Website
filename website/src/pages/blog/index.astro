---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allPosts = (await getCollection('blog', ({ data }) => data.draft !== true)).sort(
  (a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime()
);

const url = new URL(Astro.request.url);
const pillarFilter = url.searchParams.get('pillar');
const filtered = pillarFilter ? allPosts.filter((p) => p.data.pillar === pillarFilter) : allPosts;

const pillars = Array.from(new Set(allPosts.map((p) => p.data.pillar).filter(Boolean))) as string[];
---

<BaseLayout title={pillarFilter ? `${pillarFilter} — Blog | CookTwo` : 'Blog | CookTwo'} description="Long-form writing for couples on meal planning, the mental load of feeding, cooking for two different goals, and building a shared kitchen.">
  <section class="container-custom max-w-5xl py-12 md:py-20">
    <header class="mb-12">
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-text-primary mb-3">{pillarFilter ? pillarFilter : 'The CookTwo blog'}</h1>
      <p class="text-xl text-text-secondary">Long-form writing on what couples actually feed themselves — the planning, the friction, and the systems that make it easier.</p>
    </header>

    {pillars.length > 0 && (
      <nav class="mb-10 flex flex-wrap gap-2">
        <a href="/blog" class:list={["px-3 py-1.5 rounded-full text-sm border transition-colors", !pillarFilter ? "bg-sage text-white border-sage" : "border-border text-text-secondary hover:border-sage hover:text-sage"]}>All</a>
        {pillars.map((p) => (
          <a href={`/blog?pillar=${encodeURIComponent(p)}`} class:list={["px-3 py-1.5 rounded-full text-sm border transition-colors", pillarFilter === p ? "bg-sage text-white border-sage" : "border-border text-text-secondary hover:border-sage hover:text-sage"]}>{p}</a>
        ))}
      </nav>
    )}

    <div class="grid gap-6">
      {filtered.map((post) => (
        <a href={`/blog/${post.id}`} class="card group block">
          <div class="flex items-center gap-3 text-sm text-text-secondary mb-2">
            {post.data.pillar && <span class="badge-signature">{post.data.pillar}</span>}
            <time datetime={post.data.pubDate.toISOString()}>{post.data.pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</time>
            {post.data.targetKeyword && <span class="text-xs text-text-secondary">· {post.data.targetKeyword}</span>}
          </div>
          <h2 class="text-2xl font-bold text-text-primary group-hover:text-sage transition-colors mb-2">{post.data.title}</h2>
          <p class="text-text-secondary leading-relaxed">{post.data.description}</p>
        </a>
      ))}
    </div>

    {filtered.length === 0 && (
      <p class="text-text-secondary">No posts in this pillar yet.</p>
    )}
  </section>
</BaseLayout>
