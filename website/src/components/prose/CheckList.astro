---
interface Props {
  items: string[];
  variant?: 'check' | 'dot';
}

const { items, variant = 'check' } = Astro.props;
---

<ul class="not-prose my-6 space-y-3">
  {items.map((item) => (
    <li class="flex items-start gap-3">
      {variant === 'check' ? (
        <svg class="w-5 h-5 mt-0.5 text-sage flex-shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="20 6 9 17 4 12"></polyline>
        </svg>
      ) : (
        <span class="w-2 h-2 mt-2.5 rounded-full bg-sage flex-shrink-0" aria-hidden="true"></span>
      )}
      <span class="text-text-primary leading-relaxed">{item}</span>
    </li>
  ))}
</ul>
