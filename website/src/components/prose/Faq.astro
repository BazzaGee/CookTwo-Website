---
interface FaqItem {
  q: string;
  a: string;
}

interface Props {
  items: FaqItem[];
  title?: string;
}

const { items, title } = Astro.props;
---

{title && <h2 class="text-2xl font-bold text-text-primary mt-12 mb-4">{title}</h2>}
<div class="not-prose my-8 space-y-3">
  {items.map((item) => (
    <details class="group bg-white border border-border rounded-2xl overflow-hidden">
      <summary class="flex items-center justify-between gap-4 p-5 cursor-pointer list-none font-medium text-text-primary hover:text-sage transition-colors">
        <span>{item.q}</span>
        <svg class="w-5 h-5 text-sage flex-shrink-0 transition-transform group-open:rotate-180" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </summary>
      <div class="px-5 pb-5 text-text-secondary leading-relaxed border-t border-border pt-4">
        {item.a}
      </div>
    </details>
  ))}
</div>
