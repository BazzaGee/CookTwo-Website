---
interface Props {
  number: number;
  title: string;
  description?: string;
}

const { number, title, description } = Astro.props;
const padded = String(number).padStart(2, '0');
---

<div class="not-prose my-10 flex gap-5">
  <div class="flex-shrink-0 w-12 h-12 rounded-full bg-sage text-white font-bold text-lg flex items-center justify-center shadow-sm">
    {padded}
  </div>
  <div class="flex-1 pt-1">
    <h3 class="text-xl font-bold text-text-primary leading-tight mb-2">{title}</h3>
    {description && (
      <p class="text-text-secondary leading-relaxed">{description}</p>
    )}
    <div class="mt-4">
      <slot />
    </div>
  </div>
</div>
